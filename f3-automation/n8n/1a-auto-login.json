        "method": "GET",
        "url": "http://f3-cookie-crawler:3000/auto-login",
        "options": {
          "timeout": 55000
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        0,
        400
      ],
      "id": "do-login",
      "name": "🔐 Auto-Login via CDP"
    },
