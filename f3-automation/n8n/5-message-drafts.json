    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nif (data.error || data.loggedOut) {\n  return [];\n}\n// Aktuelle Top 5 – nicht nur \"unread\", sonst werden gelesene Nachrichten übersprungen\nconst items = (data.items || []).slice(0, 5);\nif (!items.length) return [];\nreturn items.map(i => ({ json: i }));"
      },
      "id": "834c313a-b9fc-43cc-b5d1-9879b0b74861",
      "name": "🔍 Nur ungelesene",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        0
      ]
    },
    {
      "parameters": {
        "url": "=http://f3-cookie-crawler:3000/messages/{{ encodeURIComponent($json.id) }}?name={{ encodeURIComponent($json.name) }}",
        "options": {
          "timeout": 55000
        }
      },
      "id": "b3c2300a-38c0-49f2-8dc3-ceb71a30863e",
      "name": "💬 Thread laden",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        672,
        0
      ],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "try {\nconst thread = $input.item.json;\nconst listItem = $('🔍 Nur ungelesene').item.json;\n\nconst messages = thread.messages || [];\nif (!messages.length) return [];\n\n// Letztes Message muss eingehend sein – sonst bereits beantwortet\nconst lastMsg = messages[messages.length - 1];\nif (!lastMsg || lastMsg.own) return [];\n\n// Schon ein KI-Draft → überspringen\nif (thread.draft) return [];\n\nconst recent = messages.slice(-10);\nconst history = recent.map(m => {\n  const who = m.own ? 'Tobi (ich)' : listItem.name;\n  return who + ': ' + m.text;\n}).join('\\n');\n\nreturn [{ json: {\n  name: listItem.name,\n  lastMessage: lastMsg.text,\n  history,\n  gender: listItem.gender || null\n}}];\n} catch(e) {\n  console.error('Kontext aufbereiten error:', e.message);\n  return [];\n}"
      },
      "id": "7fdfed5c-b259-41bc-991d-d39f4920be36",
      "name": "📋 Kontext aufbereiten",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        0
      ]
    },
    {
      "parameters": {
        "agent": "conversationalAgent",
        "promptType": "define",
        "text": "=Nachricht von :{{ $('💬 Thread laden').item.json.items[0].preview }}:\n{{ $('💬 Thread laden').item.json.items[0].preview }}",
        "options": {
          "systemMessage": "Du klassifizierst eingehende JOYclub-Nachrichten.\nAntworte IMMER nur mit einem einzigen Wort: EVENT oder ALLGEMEIN.\n\nEVENT = Frage zu einem konkreten Event (Datum, Uhrzeit, Preis, Eintritt, Dresscode, Anmeldung, Ort, Ablauf, naechstes Event, wann ist).\nALLGEMEIN = alles andere (Kennenlernen, Komplimente, persoenliche Themen, Smalltalk).\n\nKein weiterer Text. Nur EVENT oder ALLGEMEIN."
        }
      },
      "id": "classifier-agent-0001-0001-0001",
