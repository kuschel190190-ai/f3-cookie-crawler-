    {
      "parameters": {
        "jsCode": "// Filtert Events aus NocoDB nach dem heutigen Wochentag\n// Robuster als NocoDB WHERE-Filter (kein Expression-Problem)\n\nconst wochentag = $('✅ Cookie prüfen').item.json.wochentag;\nconst items = $input.all();\n\nconsole.log(`📅 Suche Event für Wochentag: ${wochentag}`);\nconsole.log(`📊 Alle Events in NocoDB: ${items.length}`);\n\n// Filter: Wochentag-Feld enthält den heutigen Tag\n// Funktioniert mit 'Mo', 'Mo,Fr', 'Mo, Fr' etc.\nconst matching = items.filter(item => {\n  const w = (item.json.Wochentag || '').replace(/\\s/g, '');\n  const tags = w.split(',');\n  return tags.includes(wochentag);\n});\n\nconsole.log(`✅ Passende Events: ${matching.length}`);\n\nif (matching.length === 0) {\n  const alleWochentage = items.map(i => i.json.Wochentag).join(', ');\n  throw new Error(\n    `Kein aktives Event für ${wochentag}! `\n    + `Verfügbare Wochentage: ${alleWochentage}`\n  );\n}\n\n// Nur das erste passende Event zurückgeben\nreturn [matching[0]];"
      },
