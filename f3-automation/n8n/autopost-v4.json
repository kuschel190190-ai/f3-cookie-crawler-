      "parameters": {
        "jsCode": "const items = $input.all();\nconst morgen = new Date();\nmorgen.setDate(morgen.getDate() + 1);\nmorgen.setHours(0,0,0,0);\n\nconst ablaufend = [];\n\nfor (const item of items) {\n  const ablauf = item.json.Ablaufdatum;\n  if (!ablauf) continue;\n  \n  const ablaufDatum = new Date(ablauf);\n  ablaufDatum.setHours(0,0,0,0);\n  \n  // Läuft in 1 Tag oder weniger ab?\n  const diffTage = Math.ceil((ablaufDatum - new Date()) / (1000 * 60 * 60 * 24));\n  \n  if (diffTage <= 1) {\n    ablaufend.push({\n      name: item.json.Name,\n      ablaufdatum: ablauf,\n      diffTage\n    });\n  }\n}\n\nif (ablaufend.length === 0) {\n  console.log('✅ Alle Cookies gültig');\n  return [{ json: { alert: false, message: 'Alle Cookies gültig' } }];\n}\n\nconst nachricht = ablaufend.map(c => \n  `⚠️ Cookie \"${c.name}\" läuft ${c.diffTage <= 0 ? 'HEUTE' : 'MORGEN'} ab! (${c.ablaufdatum})`\n).join('\\n');\n\nreturn [{ json: { alert: true, nachricht } }];"
      },
