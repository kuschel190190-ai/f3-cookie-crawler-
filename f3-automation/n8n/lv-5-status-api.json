    {
      "parameters": {
        "jsCode": "// Voting-Tag (Donnerstag) berechnen\nconst now = new Date();\nconst day = now.getDay(); // 0=So, 4=Do\nconst isVotingDay = day === 4;\nconst daysUntil = isVotingDay ? 0 : ((4 - day + 7) % 7) || 7;\n\nconst next = new Date(now);\nnext.setDate(now.getDate() + daysUntil);\n\nconst fmt = d => d.toLocaleDateString('de-DE', {\n  day: '2-digit', month: '2-digit', year: 'numeric'\n});\n\n// Letzten Sync-Zeitpunkt aus NocoDB (CreatedAt des letzten gesendeten Eintrags)\nconst lastRecord = $input.first().json.list?.[0];\nlet lastSyncAt = '—';\nif (lastRecord?.CreatedAt) {\n  try {\n    lastSyncAt = new Date(lastRecord.CreatedAt).toLocaleString('de-DE', {\n      day: '2-digit', month: '2-digit', year: 'numeric',\n      hour: '2-digit', minute: '2-digit'\n    });\n  } catch(e) {}\n}\n\nreturn [{ json: {\n  isVotingDay,\n  daysUntil,\n  nextVotingDate: fmt(next),\n  lastSyncAt\n}}];"
      },
