    {
      "parameters": {
        "jsCode": "// Kandidaten-Liste aus NocoDB aufbereiten\nconst cookieStr = $('?? Cookies aus NocoDB').first().json.Cookie || '';\nconst records = $input.first().json.list || [];\n\nif (records.length === 0) {\n  console.log('Keine Kandidaten mit Status=neu gefunden.');\n  return [];\n}\n\nreturn records.map(r => ({ json: {\n  _nocodb_id: r.Id,\n  profileUrl:  r.ProfilUrl,\n  _cookie:     cookieStr\n}}));"
      },
