      "id": "e445a35c-9a42-4d1a-91e6-eec04eb7e7ee",
      "name": "?? Profil-Seite abrufen"
    },
    {
      "parameters": {
        "jsCode": "const html   = $input.item.json.data || '';\nconst prev   = $('📂 Kandidaten aufbereiten').item.json;\nconst profUrl = prev.profileUrl || '';\n\n// Benutzername aus URL: /profile/12345678.username.html\nconst usernameMatch = profUrl.match(/\\/profile\\/\\d+\\.([^.]+)\\.html/);\nconst username = usernameMatch ? usernameMatch[1] : '';\n\n// Galeriefotos aus JOYclub CDN (öffentlich, kein Auth nötig)\nconst cdnRx = /https?:\\/\\/(?:cdn\\d*|img)\\.joyclub\\.de\\/[^\"'<>\\s]+\\.(?:jpg|jpeg|png|webp)/gi;\nconst rawPhotos = [...html.matchAll(cdnRx)].map(m => m[0]);\nconst photos = [...new Set(rawPhotos)]\n  .filter(u => !u.includes('_thumb') && !u.includes('_small') && !u.includes('icon') && !u.includes('logo'))\n  .slice(0, 3);\n\nconst patch = { Username: username, Fotos: JSON.stringify(photos), Status: 'fotos_geladen' };\nreturn [{ json: {\n  _nocodb_id:  prev._nocodb_id,\n  _patchBody:  JSON.stringify(patch)\n}}];"
      },
